# Deploy Configuration
# Copy this file to deploy.conf and fill in your values
# Keep deploy.conf secure - it contains secrets!

# Cloudflare API Credentials
# Required for CF proxy mode, optional for --direct mode
# Get token at: https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Zone → DNS → Edit, Zone → Zone → Read
CF_TOKEN="your-cloudflare-api-token"
CF_ZONE_ID="your-zone-id"

# 3x-ui Panel Defaults
# Password will auto-generate if left as "changeme123"
XUI_USER="admin"
XUI_PASS="changeme123"

# API Registration (optional - leave empty to skip)
# Used to register servers with a central management API
API_ENDPOINT=""
API_TOKEN=""
