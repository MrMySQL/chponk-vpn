# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Encryption (exactly 32 characters for AES-256)
ENCRYPTION_KEY=your-32-character-encryption-key

# Test Server
TEST_DROPLET_IP=your-server-ip

# Domain Settings
TEST_DOMAIN=test.myvpn.xyz

# Cloudflare (for DNS management - gray cloud, no proxy)
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE_ID=your-cloudflare-zone-id

# 3x-ui Panel
XUI_USER=admin
XUI_PASS=your-secure-password

# Reality Settings (optional - defaults shown)
# REALITY_DEST=www.microsoft.com:443
# REALITY_SNI=microsoft.com

# API Registration
API_ENDPOINT=https://your-app.vercel.app/api/servers/register
API_TOKEN=your-api-token

# Server Info
SERVER_NAME=Test Server
SERVER_LOCATION=Test Location
FLAG_EMOJI=🧪

# SSH (optional)
SSH_USER=root
# SSH_KEY=/path/to/private/key
